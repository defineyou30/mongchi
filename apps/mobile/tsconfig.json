{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@mongchi/shared": [
        "../../packages/shared/src"
      ],
      "@mongchi/shared/*": [
        "../../packages/shared/src/*"
      ],
      "react-native-svg": [
        "node_modules/react-native-svg"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
