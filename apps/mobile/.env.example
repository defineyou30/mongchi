# Public mobile API base URL for backend integration builds.
# Keep provider keys, service tokens, payment secrets, and receipt secrets out of this file.
EXPO_PUBLIC_TINY_PET_API_BASE_URL=https://api.example.com

# Public mock user id for local API adapter builds only. Do not use real session/provider tokens here.
EXPO_PUBLIC_TINY_PET_ALLOW_DEVELOPMENT_AUTH_FALLBACK=true
EXPO_PUBLIC_TINY_PET_MOCK_AUTH_TOKEN=user_demo_001

# Production builds must set EXPO_PUBLIC_TINY_PET_ALLOW_DEVELOPMENT_AUTH_FALLBACK=false
# and must leave EXPO_PUBLIC_TINY_PET_MOCK_AUTH_TOKEN unset.

# Public release links shown in Settings, Privacy, Terms, and Support screens.
# Production builds must replace these with owned HTTPS pages and a monitored support inbox.
EXPO_PUBLIC_TINY_PET_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_TINY_PET_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_TINY_PET_SUPPORT_EMAIL=support@example.com

# Native checkout is disabled unless explicitly enabled in a custom development
# or production build with server-side receipt verification already deployed.
EXPO_PUBLIC_TINY_PET_ENABLE_NATIVE_CHECKOUT=false

# Optional QA-only store screenshot preset for deterministic store capture.
# Supported values include welcome, pet-setup, photo-upload, hatching,
# pet-reveal, terrarium, chat, walk-reward, and shop.
# Production release-config validation rejects this value when it is set.
EXPO_PUBLIC_TINY_PET_STORE_SCREENSHOT_PRESET=

# Optional QA-only screen preset for deterministic iOS evidence capture.
# Supported values include settings-privacy-error and settings-privacy-progress.
# Production release-config validation rejects this value when it is set.
EXPO_PUBLIC_TINY_PET_QA_SCREEN_PRESET=
