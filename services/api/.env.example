# Local API adapter defaults. Production deployments must set every
# TINY_PET_API_ALLOW_MOCK_* flag below to false and mount real server providers.
TINY_PET_RELEASE_PROFILE=development
TINY_PET_API_ALLOW_MOCK_AUTH=true
TINY_PET_API_ALLOW_MOCK_PURCHASES=true
TINY_PET_API_ALLOW_MOCK_STORAGE=true
TINY_PET_API_ALLOW_MOCK_GENERATION_POLLING=true

# API process settings.
TINY_PET_API_HOST=127.0.0.1
TINY_PET_API_PORT=8787
TINY_PET_API_ALLOWED_ORIGINS=
TINY_PET_API_MAX_BODY_BYTES=1048576
TINY_PET_API_RATE_LIMIT_WINDOW_MS=60000
TINY_PET_API_RATE_LIMIT_MAX_REQUESTS=120
TINY_PET_API_SERVICE_NAME=tiny-pet-api
TINY_PET_OPERATIONAL_ALERT_ROUTING=json_logs
TINY_PET_OPERATIONAL_ALERT_WEBHOOK_URL=
TINY_PET_OPERATIONAL_ALERT_WEBHOOK_BEARER_TOKEN=
TINY_PET_OPERATIONAL_ALERT_WEBHOOK_TIMEOUT_MS=5000

# Production API deployments should configure these server-only values when
# using the built-in RS256 JWT/JWKS session verifier.
TINY_PET_AUTH_ISSUER=
TINY_PET_AUTH_AUDIENCE=
TINY_PET_AUTH_JWKS_URL=
TINY_PET_AUTH_PROVIDER=tiny-pet-auth
TINY_PET_AUTH_USER_ID_CLAIM=sub
TINY_PET_AUTH_CLOCK_TOLERANCE_SECONDS=30
TINY_PET_AUTH_JWKS_CACHE_TTL_MS=600000

# Production API deployments must provide Postgres. Local development can omit
# this while using the mock service.
TINY_PET_DATABASE_URL=
TINY_PET_DATABASE_SSL_MODE=require
TINY_PET_DATABASE_MAX_POOL_SIZE=10
TINY_PET_DATABASE_CONNECT_TIMEOUT_MS=5000

# Private storage signing for original-photo uploads and generated asset reads.
# Production deployments must use private bucket credentials from secret storage.
TINY_PET_STORAGE_BUCKET=
TINY_PET_STORAGE_REGION=
TINY_PET_STORAGE_ENDPOINT=
TINY_PET_STORAGE_FORCE_PATH_STYLE=false
TINY_PET_STORAGE_ACCESS_KEY_ID=
TINY_PET_STORAGE_SECRET_ACCESS_KEY=
TINY_PET_STORAGE_SESSION_TOKEN=
TINY_PET_STORAGE_ORIGINAL_PHOTO_PREFIX=source/originals
TINY_PET_STORAGE_UPLOAD_EXPIRES_SECONDS=600
TINY_PET_STORAGE_READ_EXPIRES_SECONDS=600

# Store purchase verification. Use either an HTTP verifier gateway or direct
# App Store / Google Play credentials; keep raw store tokens request-scoped only.
TINY_PET_STORE_VERIFIER_PROVIDER=http
TINY_PET_STORE_VERIFIER_ENDPOINT=
TINY_PET_STORE_VERIFIER_API_KEY=
TINY_PET_APP_STORE_ENVIRONMENT=production
TINY_PET_APP_STORE_ISSUER_ID=
TINY_PET_APP_STORE_KEY_ID=
TINY_PET_APP_STORE_BUNDLE_ID=
TINY_PET_APP_STORE_PRIVATE_KEY=
TINY_PET_APP_STORE_NOTIFICATION_ROOT_CERT_SHA256=
TINY_PET_APP_STORE_BASE_URL=
TINY_PET_GOOGLE_PLAY_PACKAGE_NAME=
TINY_PET_GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
TINY_PET_GOOGLE_PLAY_PRIVATE_KEY=
TINY_PET_GOOGLE_PLAY_SUBSCRIPTION_PRODUCT_IDS=
TINY_PET_GOOGLE_PLAY_BASE_URL=
TINY_PET_COMMERCE_WEBHOOK_SECRET=

# Premium chat provider. This key is server-only and must never be exposed to
# mobile public env files.
TINY_PET_PREMIUM_CHAT_OPENAI_API_KEY=
TINY_PET_PREMIUM_CHAT_OPENAI_MODEL=
TINY_PET_PREMIUM_CHAT_OPENAI_BASE_URL=
TINY_PET_PREMIUM_CHAT_OPENAI_MAX_OUTPUT_TOKENS=500
TINY_PET_PREMIUM_CHAT_RATE_LIMIT_MAX_MESSAGES=10
TINY_PET_PREMIUM_CHAT_RATE_LIMIT_WINDOW_MS=60000
TINY_PET_PREMIUM_CHAT_CONTEXT_MESSAGE_LIMIT=16
TINY_PET_PREMIUM_CHAT_RETENTION_WINDOW_MS=2592000000

# Generation worker deployment. Worker DB/storage values default to API values
# when omitted, but production scheduler env should normally set them explicitly.
TINY_PET_WORKER_DATABASE_URL=
TINY_PET_WORKER_DATABASE_SSL_MODE=require
TINY_PET_WORKER_DATABASE_MAX_POOL_SIZE=4
TINY_PET_WORKER_DATABASE_CONNECT_TIMEOUT_MS=5000
TINY_PET_WORKER_STORAGE_BUCKET=
TINY_PET_WORKER_STORAGE_REGION=
TINY_PET_WORKER_STORAGE_ENDPOINT=
TINY_PET_WORKER_STORAGE_FORCE_PATH_STYLE=false
TINY_PET_WORKER_STORAGE_ACCESS_KEY_ID=
TINY_PET_WORKER_STORAGE_SECRET_ACCESS_KEY=
TINY_PET_WORKER_STORAGE_SESSION_TOKEN=
TINY_PET_WORKER_STORAGE_GENERATED_ASSET_PREFIX=generated-assets
TINY_PET_WORKER_GENERATION_PROVIDER=openai
TINY_PET_WORKER_PROVIDER_API_KEY=
TINY_PET_WORKER_PROVIDER_MODEL=
TINY_PET_WORKER_PROVIDER_SAFETY_MODEL=
TINY_PET_WORKER_PROCESS_MODE=once
TINY_PET_WORKER_POLL_INTERVAL_MS=5000
TINY_PET_WORKER_MAX_RUNS=1
TINY_PET_WORKER_MAX_JOBS_PER_RUN=1
TINY_PET_WORKER_STOP_ON_IDLE=false
TINY_PET_WORKER_STOP_ON_FAILURE=false
TINY_PET_WORKER_STOP_PROCESS_ON_FAILURE=false
TINY_PET_WORKER_QUALITY_MIN_PET_VISIBILITY_CONFIDENCE=
TINY_PET_WORKER_QUALITY_MIN_STYLE_MATCH_SCORE=
TINY_PET_WORKER_QUALITY_MIN_PROVIDER_CONFIDENCE=
TINY_PET_WORKER_QUALITY_CALIBRATION_ID=

# Privacy deletion, outbox, and chat-retention workers.
TINY_PET_PRIVACY_WORKER_PROCESS_MODE=once
TINY_PET_PRIVACY_WORKER_POLL_INTERVAL_MS=5000
TINY_PET_PRIVACY_WORKER_MAX_RUNS=1
TINY_PET_PRIVACY_WORKER_STOP_ON_IDLE=false
TINY_PET_PRIVACY_WORKER_STOP_PROCESS_ON_FAILURE=false
TINY_PET_OUTBOX_WORKER_PROCESS_MODE=once
TINY_PET_OUTBOX_WORKER_POLL_INTERVAL_MS=5000
TINY_PET_OUTBOX_WORKER_MAX_RUNS=1
TINY_PET_OUTBOX_WORKER_STOP_ON_IDLE=false
TINY_PET_OUTBOX_WORKER_STOP_PROCESS_ON_FAILURE=false
TINY_PET_CHAT_RETENTION_WORKER_PROCESS_MODE=once
TINY_PET_CHAT_RETENTION_WORKER_POLL_INTERVAL_MS=5000
TINY_PET_CHAT_RETENTION_WORKER_MAX_RUNS=1
TINY_PET_CHAT_RETENTION_WORKER_BATCH_SIZE=100
TINY_PET_CHAT_RETENTION_WORKER_RETENTION_WINDOW_MS=2592000000
TINY_PET_CHAT_RETENTION_WORKER_STOP_ON_IDLE=false
