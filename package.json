{
  "name": "mongchi",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "workers/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:mobile-assets": "node scripts/generate-mobile-assets.mjs",
    "generate:mobile-asset-contact-sheet": "node scripts/generate-mobile-asset-contact-sheet.mjs",
    "validate:mobile-assets": "node scripts/validate-mobile-assets.mjs",
    "validate:mobile-audio-assets": "node scripts/analyze-mobile-audio-assets.mjs --output /tmp/mongchi-audio-analysis.json",
    "validate:mobile-asset-contact-sheet": "node scripts/validate-mobile-asset-contact-sheet.mjs",
    "validate:mobile-visual-assets": "node scripts/validate-mobile-visual-asset-quality.mjs",
    "validate:mobile-visual-direction": "node scripts/validate-mobile-visual-direction.mjs",
    "validate:mobile-flow": "node scripts/validate-mobile-flow.mjs",
    "validate:mobile-copy": "node scripts/validate-mobile-copy.mjs",
    "validate:product-direction": "node scripts/validate-product-direction-doc.mjs",
    "validate:plant-growth-design": "node scripts/validate-plant-growth-design.mjs",
    "validate:plant-stage-assets": "node scripts/validate-plant-stage-assets.mjs",
    "validate:care-economy-design": "node scripts/validate-care-economy-design.mjs",
    "validate:pet-avatar-prompt-design": "node scripts/validate-pet-avatar-prompt-design.mjs",
    "validate:pet-avatar-fallback-assets": "node scripts/validate-pet-avatar-fallback-assets.mjs",
    "validate:ios-manual-qa": "node scripts/validate-ios-manual-qa-docs.mjs",
    "validate:privacy-sdk-boundaries": "node scripts/validate-privacy-sdk-boundaries.mjs",
    "validate:native-store-config": "node scripts/validate-native-store-config.mjs",
    "validate:store-compliance": "node scripts/validate-store-compliance-docs.mjs",
    "validate:store-listing": "node scripts/validate-store-listing-docs.mjs",
    "validate:store-metadata-alignment": "node scripts/validate-store-metadata-alignment.mjs",
    "validate:store-screenshots": "node scripts/validate-store-screenshots.mjs",
    "validate:ios-store-screenshots": "TINY_PET_REQUIRE_STORE_SCREENSHOTS=ios node scripts/validate-store-screenshots.mjs",
    "validate:android-store-screenshots": "TINY_PET_REQUIRE_STORE_SCREENSHOTS=android node scripts/validate-store-screenshots.mjs",
    "validate:final-screenshot-freshness": "node scripts/validate-final-screenshot-freshness.mjs",
    "validate:ios-final-screenshot-freshness": "TINY_PET_FINAL_SCREENSHOT_FRESHNESS_PLATFORMS=ios node scripts/validate-final-screenshot-freshness.mjs",
    "generate:ios-store-contact-sheet": "node scripts/generate-ios-store-contact-sheet.mjs",
    "validate:ios-store-contact-sheet": "node scripts/validate-ios-store-contact-sheet.mjs",
    "generate:android-store-contact-sheet": "node scripts/generate-android-store-contact-sheet.mjs",
    "validate:android-store-contact-sheet": "node scripts/validate-android-store-contact-sheet.mjs",
    "capture:ios-store-screenshots": "node scripts/capture-ios-store-screenshots.mjs",
    "capture:android-store-screenshots": "node scripts/capture-android-store-screenshots.mjs",
    "capture:ios-large-text-evidence": "node scripts/capture-ios-large-text-evidence.mjs",
    "generate:ios-large-text-contact-sheet": "TINY_PET_IOS_STORE_CONTACT_LABEL_PREFIX=large-text node scripts/generate-ios-store-contact-sheet.mjs",
    "validate:ios-large-text-evidence": "node scripts/validate-ios-large-text-evidence.mjs",
    "capture:ios-reduce-motion-hatching": "node scripts/capture-ios-reduce-motion-hatching.mjs",
    "capture:ios-reduce-motion-core-evidence": "node scripts/capture-ios-reduce-motion-core-evidence.mjs",
    "validate:ios-reduce-motion-evidence": "node scripts/validate-ios-reduce-motion-evidence.mjs",
    "capture:ios-settings-privacy-evidence": "node scripts/capture-ios-settings-privacy-evidence.mjs",
    "capture:ios-settings-privacy-progress-evidence": "TINY_PET_IOS_SETTINGS_PRIVACY_PRESET=settings-privacy-progress node scripts/capture-ios-settings-privacy-evidence.mjs",
    "validate:ios-settings-privacy-evidence": "node scripts/validate-ios-settings-privacy-evidence.mjs",
    "validate:ios-dev-client-readiness": "node scripts/validate-ios-dev-client-readiness.mjs",
    "ios:pods": "node scripts/run-ios-pod-install.mjs",
    "ios:dev-client:build": "node scripts/build-ios-dev-client.mjs",
    "validate:ios-preflight": "node scripts/validate-ios-preflight.mjs",
    "qa:mobile-screenshots": "node scripts/capture-mobile-qa-screenshots.mjs",
    "start:landing": "npm --workspace @mongchi/landing run dev -- --host 127.0.0.1",
    "build:landing": "npm --workspace @mongchi/landing run build",
    "preview:landing": "npm --workspace @mongchi/landing run preview -- --host 127.0.0.1",
    "start:mobile": "npm --workspace @mongchi/mobile run start",
    "start:mobile:dev-client": "NODE_OPTIONS=--dns-result-order=ipv4first npm --workspace @mongchi/mobile run start -- --dev-client --port 8091 --host localhost",
    "test": "vitest run --exclude '**/.omo/**'",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:worker",
    "typecheck:api": "tsc -p services/api --pretty",
    "typecheck:shared": "tsc -p packages/shared --pretty",
    "typecheck:worker": "tsc -p workers/ai --pretty",
    "validate:mobile-accessibility": "node scripts/validate-mobile-accessibility.mjs",
    "validate:mobile-secret-boundaries": "node scripts/validate-mobile-secret-boundaries.mjs",
    "validate:db-migrations": "node scripts/validate-db-migrations.mjs",
    "validate:release-config": "node scripts/validate-release-config.mjs",
    "validate:production-release-config": "TINY_PET_RELEASE_PROFILE=production node scripts/validate-release-config.mjs",
    "validate:final-release-runbook": "node scripts/validate-final-release-runbook.mjs",
    "validate:final-release-plan": "TINY_PET_FINAL_RELEASE_DRY_RUN=true node scripts/validate-final-release-readiness.mjs",
    "validate:final-release": "node scripts/validate-final-release-readiness.mjs",
    "validate:env-examples": "node scripts/validate-env-examples.mjs",
    "validate:android": "npm --workspace @mongchi/mobile run validate:android",
    "validate:ios": "npm --workspace @mongchi/mobile run validate:ios",
    "start:api": "npm --workspace @mongchi/api run start:api",
    "start:generation-worker": "npm --workspace @mongchi/api run start:generation-worker",
    "start:privacy-worker": "npm --workspace @mongchi/api run start:privacy-worker",
    "start:outbox-worker": "npm --workspace @mongchi/api run start:outbox-worker",
    "start:chat-retention-worker": "npm --workspace @mongchi/api run start:chat-retention-worker"
  },
  "devDependencies": {
    "pngjs": "^3.4.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@expo-google-fonts/baloo-2": "^0.4.2",
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo-google-fonts/pixelify-sans": "^0.4.2",
    "expo-font": "~56.0.7",
    "expo": "~56.0.12",
    "react": "19.2.3",
    "react-native": "0.85.3"
  }
}
